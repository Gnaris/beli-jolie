// Prisma Schema — Beli & Jolie
// Base de données MySQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Rôles utilisateur
// ─────────────────────────────────────────────
enum Role {
  ADMIN
  CLIENT
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClientDiscountType {
  PERCENT  // remise en %
  AMOUNT   // remise en €
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  firstName String
  lastName  String
  company   String
  phone     String
  siret     String     @unique
  kbisPath  String?
  documentPath String?          // Document libre envoyé lors de l'inscription
  registrationMessage String?  // Message libre lors de l'inscription
  address          String?    // Adresse de l'entreprise
  vatNumber        String?    // Numéro TVA intracommunautaire (ex: FR12345678901)
  stripeCustomerId String?    @unique // cus_xxx — requis pour le virement bancaire
  role             Role       @default(CLIENT)
  status           UserStatus @default(PENDING)
  // Remise commerciale permanente
  discountType     ClientDiscountType?  // null = pas de remise
  discountValue    Float?               // % ou montant €
  freeShipping     Boolean              @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  cart          Cart?
  addresses     ShippingAddress[]
  orders        Order[]
  favorites     Favorite[]
  importDrafts  ImportDraft[]
  importJobs    ImportJob[]
  accessCodes   AccessCode[]
  activity      UserActivity?
  restockAlerts RestockAlert[]
}

// ─────────────────────────────────────────────
// Favoris
// ─────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// Catalogue produits
// ─────────────────────────────────────────────

enum SaleType {
  UNIT // Vendu à l'unité
  PACK // Vendu par paquet de X unités
}

enum DiscountType {
  PERCENT // Remise en %
  AMOUNT  // Remise en €
}

enum ProductStatus {
  OFFLINE   // Hors ligne (brouillon)
  ONLINE    // En ligne (visible sur le catalogue public)
  ARCHIVED  // Archivé (invisible, conservé pour historique commandes)
}

// Catégorie principale (ex: Colliers, Bracelets)
model Category {
  id            String                @id @default(cuid())
  name          String                @unique
  slug          String                @unique
  subCategories SubCategory[]
  products      Product[]
  translations  CategoryTranslation[]
  createdAt     DateTime              @default(now())
}

model CategoryTranslation {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale     String
  name       String
  createdAt  DateTime @default(now())

  @@unique([categoryId, locale])
}

// Sous-catégorie (ex: Sautoir, Jonc)
model SubCategory {
  id           String                   @id @default(cuid())
  name         String
  slug         String
  categoryId   String
  category     Category                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products     Product[]                @relation("ProductSubCategories")
  translations SubCategoryTranslation[]
  createdAt    DateTime                 @default(now())

  @@unique([name, categoryId])
}

model SubCategoryTranslation {
  id            String      @id @default(cuid())
  subCategoryId String
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  locale        String
  name          String
  createdAt     DateTime    @default(now())

  @@unique([subCategoryId, locale])
}

// Bibliothèque de couleurs réutilisables entre produits
model Color {
  id            String                  @id @default(cuid())
  name          String                  @unique
  hex           String?
  patternImage  String?                 // Image motif (léopard, camouflage, carreaux…) — prioritaire sur hex
  createdAt     DateTime                @default(now())
  productColors ProductColor[]
  colorImages   ProductColorImage[]
  translations  ColorTranslation[]
  subColorUsages ProductColorSubColor[] // Utilisations en tant que sous-couleur
}

model ColorTranslation {
  id        String   @id @default(cuid())
  colorId   String
  color     Color    @relation(fields: [colorId], references: [id], onDelete: Cascade)
  locale    String
  name      String
  createdAt DateTime @default(now())

  @@unique([colorId, locale])
}

// Bibliothèque de compositions (matériaux)
model Composition {
  id           String                  @id @default(cuid())
  name         String                  @unique
  createdAt    DateTime                @default(now())
  products     ProductComposition[]
  translations CompositionTranslation[]
}

model CompositionTranslation {
  id            String      @id @default(cuid())
  compositionId String
  composition   Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  locale        String
  name          String
  createdAt     DateTime    @default(now())

  @@unique([compositionId, locale])
}

// Liaison produit ↔ composition avec pourcentage
model ProductComposition {
  id            String      @id @default(cuid())
  productId     String
  compositionId String
  percentage    Float       // ex: 85.5 pour 85.5%
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  composition   Composition @relation(fields: [compositionId], references: [id])

  @@unique([productId, compositionId])
}

// Tags (mots-clés pour recherche)
model Tag {
  id           String           @id @default(cuid())
  name         String           @unique
  products     ProductTag[]
  translations TagTranslation[]
  createdAt    DateTime         @default(now())
}

model TagTranslation {
  id        String   @id @default(cuid())
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  locale    String
  name      String
  createdAt DateTime @default(now())

  @@unique([tagId, locale])
}

model ProductTag {
  productId String
  tagId     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

// Produit principal
model Product {
  id            String               @id @default(cuid())
  reference     String               @unique
  name          String
  description   String               @db.Text
  categoryId    String
  category      Category             @relation(fields: [categoryId], references: [id])
  subCategories SubCategory[]        @relation("ProductSubCategories")
  colors        ProductColor[]
  colorImages   ProductColorImage[]
  compositions  ProductComposition[]
  collections   CollectionProduct[]
  favorites     Favorite[]
  tags          ProductTag[]
  translations  ProductTranslation[]
  catalogs      CatalogProduct[]
  accessCodeViews AccessCodeView[]
  restockAlerts   RestockAlert[]
  isBestSeller  Boolean              @default(false)
  status        ProductStatus        @default(OFFLINE)
  // Produits similaires (M2M self)
  similarProducts ProductSimilar[]   @relation("PSim_A")
  similarTo       ProductSimilar[]   @relation("PSim_B")
  // Dimensions optionnelles (en mm)
  dimensionLength        Float?
  dimensionWidth         Float?
  dimensionHeight        Float?
  dimensionDiameter      Float?
  dimensionCircumference Float?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  // Performance indexes for 78k+ products
  @@index([status, createdAt])          // catalog listing (default sort)
  @@index([status, updatedAt])          // "new" filter sort
  @@index([categoryId, status])         // category filter
  @@index([isBestSeller, status])       // bestseller filter
  @@index([status, name])               // search by name
  @@index([createdAt])                  // general date sorting
  @@index([reference])                  // exact reference search
}

// Traductions automatiques des produits
model ProductTranslation {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale      String   // "en" | "ar"
  name        String
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, locale])
  @@index([productId])
  @@index([locale])                     // admin warnings: count by locale
}

// Produits similaires (M2M self-relation)
model ProductSimilar {
  productId String
  similarId String
  product   Product @relation("PSim_A", fields: [productId], references: [id], onDelete: Cascade)
  similar   Product @relation("PSim_B", fields: [similarId], references: [id], onDelete: Cascade)

  @@id([productId, similarId])
}

// Deferred similar product links — stores references that don't exist yet at import time.
// Resolved automatically when matching products are created later.
model PendingSimilar {
  id             String  @id @default(cuid())
  productRef     String  // reference of the source product (already exists)
  similarRef     String  // reference of the target product (may not exist yet)
  createdAt      DateTime @default(now())

  @@unique([productRef, similarRef])
  @@index([similarRef])
}

// Variante plate d'un produit (couleur + type de vente + prix + stock)
// Une même couleur peut apparaître plusieurs fois (UNIT, PACK×12, PACK×24…)
model ProductColor {
  id          String       @id @default(cuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorId     String
  color       Color        @relation(fields: [colorId], references: [id])
  unitPrice   Float        // Prix par unité HT
  weight      Float        // Poids en kg (ex: 0.008)
  stock       Int          @default(0)
  isPrimary   Boolean      @default(false)
  saleType    SaleType     // UNIT ou PACK
  packQuantity Int?        // Quantité par paquet (null si UNIT)
  size        String?      // Taille (ex: 17, 18, L, XL) — optionnel
  discountType  DiscountType? // Type de remise (null = pas de remise)
  discountValue Float?        // Valeur de la remise
  subColors   ProductColorSubColor[] // Sous-couleurs optionnelles (ex: Doré → Rouge, Noir)
  cartItems   CartItem[]
  collectionOverrides CollectionProduct[] // Apparitions dans des collections avec cette couleur
  restockAlerts RestockAlert[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([productId, colorId])
  @@index([productId, isPrimary])       // fast primary color lookup
  @@index([colorId])                    // color filter queries
  @@index([discountType, discountValue]) // promo filter
  @@index([stock])                      // OOS filter
  @@index([unitPrice])                  // price range filter
}

// Sous-couleurs optionnelles d'une variante (ex: Doré/Rouge/Noir)
// Utilise la même bibliothèque Color que la couleur principale
model ProductColorSubColor {
  id             String       @id @default(cuid())
  productColorId String
  productColor   ProductColor @relation(fields: [productColorId], references: [id], onDelete: Cascade)
  colorId        String
  color          Color        @relation(fields: [colorId], references: [id])
  position       Int          @default(0) // Ordre d'affichage

  @@unique([productColorId, colorId])
  @@index([productColorId])
}

// Images liées à un (produit, couleur) — partagées entre toutes les variantes de la même couleur
model ProductColorImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorId   String
  color     Color    @relation(fields: [colorId], references: [id])
  path      String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId, colorId])
}

// ─────────────────────────────────────────────
// Panier & commandes
// ─────────────────────────────────────────────

// Panier persistant en base (un par utilisateur)
model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// Ligne du panier — liée directement à une variante plate
model CartItem {
  id        String       @id @default(cuid())
  cartId    String
  cart      Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductColor @relation(fields: [variantId], references: [id])
  quantity  Int          @default(1)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([variantId])                  // variant price change impact queries
}

// ─────────────────────────────────────────────
// Commandes
// ─────────────────────────────────────────────

enum OrderStatus {
  PENDING     // En attente de traitement
  PROCESSING  // En préparation
  SHIPPED     // Expédiée
  DELIVERED   // Livrée
  CANCELLED   // Annulée
}

// Commande validée par le client
model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique // ex: BJ-2026-000001
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  items       OrderItem[]
  status      OrderStatus @default(PENDING)

  // Snapshot adresse de livraison
  shipLabel     String
  shipFirstName String
  shipLastName  String
  shipCompany   String?
  shipAddress1  String
  shipAddress2  String?
  shipZipCode   String
  shipCity      String
  shipCountry   String

  // Snapshot client
  clientCompany   String
  clientEmail     String
  clientPhone     String
  clientSiret     String
  clientVatNumber String?

  // Transporteur
  carrierId    String
  carrierName  String
  carrierPrice Float

  // Remise commerciale client (snapshot au moment de la commande)
  clientDiscountType  ClientDiscountType?
  clientDiscountValue Float?
  clientDiscountAmt   Float              @default(0)  // montant économisé en €
  clientFreeShipping  Boolean            @default(false)

  // TVA
  tvaRate    Float  // ex: 0.20
  subtotalHT Float
  tvaAmount  Float
  totalTTC   Float

  // Stripe
  stripePaymentIntentId String?  @unique // pi_xxx
  paymentStatus         String   @default("pending") // pending | paid | failed

  // Easy-Express
  eeTrackingId String?  // Numéro de suivi
  eeLabelUrl   String?  // URL du bordereau PDF @db.Text

  // Facture uploadée par l'admin
  invoicePath String?  // Chemin relatif depuis /private/uploads/invoices/

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId, createdAt])
  @@index([userId, status])             // client order listing with status filter
  @@index([paymentStatus])              // payment status queries
  @@index([createdAt])                  // admin order listing
  @@index([status, createdAt])          // admin filtered + paginated listing
}

// Ligne de commande (snapshot produit au moment de la commande)
model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productName String
  productRef  String
  colorName   String
  saleType    String  // "UNIT" | "PACK"
  packQty     Int?
  size        String?
  imagePath   String? // première image (relatif /public)

  unitPrice   Float   // prix unitaire calculé (remise incluse)
  quantity    Int
  lineTotal   Float

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productRef])                 // bestseller groupBy + reassort queries
}

// ─────────────────────────────────────────────
// Collections
// ─────────────────────────────────────────────

// Collection (ex: "Été 2026", "Romantique", "Minimaliste")
model Collection {
  id          String              @id @default(cuid())
  name        String
  image       String?             // Chemin relatif depuis /public
  products    CollectionProduct[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

// Liaison produit ↔ collection avec couleur et ordre d'affichage
model CollectionProduct {
  id           String        @id @default(cuid())
  collectionId String
  collection   Collection    @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorId      String?       // Couleur à afficher dans cette collection (null = couleur primaire)
  productColor ProductColor? @relation(fields: [colorId], references: [id])
  position     Int           @default(0)
  createdAt    DateTime      @default(now())

  @@unique([collectionId, productId])
  @@index([collectionId])
}

// Adresse de livraison (plusieurs par utilisateur)
model ShippingAddress {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String   // ex: "Boutique principale"
  firstName  String
  lastName   String
  company    String?
  address1   String
  address2   String?
  zipCode    String
  city       String
  country    String   @default("FR")
  phone      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Catalogues partageables
// ─────────────────────────────────────────────

enum CatalogStatus {
  DRAFT      // Brouillon (non accessible via lien)
  PUBLISHED  // Publié (accessible via lien)
}

model Catalog {
  id             String           @id @default(cuid())
  title          String
  token          String           @unique @default(cuid()) // token public pour le lien
  primaryColor   String           @default("#1A1A1A")      // couleur principale du catalogue
  coverImagePath String?                                   // photo de fond du header (remplace la couleur)
  status         CatalogStatus    @default(DRAFT)
  products       CatalogProduct[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model CatalogProduct {
  id              String   @id @default(cuid())
  catalogId       String
  catalog         Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  position          Int      @default(0)
  selectedColorId   String?  // Color.id sélectionné pour ce produit dans ce catalogue (null = couleur primaire par défaut)
  selectedImagePath String?  // chemin image spécifique à afficher dans ce catalogue (null = première image de la couleur)
  createdAt         DateTime @default(now())

  @@unique([catalogId, productId])
}

// ─────────────────────────────────────────────
// Codes d'accès invité
// ─────────────────────────────────────────────

model AccessCode {
  id            String           @id @default(cuid())
  code          String           @unique      // ex: BELI-A3X7
  note          String?          @db.Text     // Note admin (à qui, pourquoi, etc.)
  expiresAt     DateTime                      // Expiration (1 semaine par défaut)
  isActive      Boolean          @default(true)

  // Pré-remplissage inscription (optionnel, renseigné par l'admin)
  prefillFirstName String?
  prefillLastName  String?
  prefillCompany   String?
  prefillEmail     String?
  prefillPhone     String?

  // Inscription via ce code
  usedBy        String?                       // User.id du client inscrit
  usedByName    String?                       // Nom complet du client inscrit
  usedAt        DateTime?                     // Date d'inscription
  user          User?            @relation(fields: [usedBy], references: [id], onDelete: SetNull)

  // Tracking navigation
  firstAccessAt DateTime?                     // Première utilisation pour naviguer
  lastAccessAt  DateTime?                     // Dernier accès
  views         AccessCodeView[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([code])
  @@index([expiresAt])
}

model AccessCodeView {
  id            String      @id @default(cuid())
  accessCodeId  String
  accessCode    AccessCode  @relation(fields: [accessCodeId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName   String?                      // Snapshot du nom produit
  pageUrl       String                       // URL visitée
  createdAt     DateTime    @default(now())

  @@index([accessCodeId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// Activité utilisateur (heartbeat en ligne)
// ─────────────────────────────────────────────

model UserActivity {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastSeenAt    DateTime @default(now())
  connectedAt   DateTime @default(now())
  currentPage   String?
  cartAddsCount Int      @default(0)
  favAddsCount  Int      @default(0)

  @@index([lastSeenAt])
}

// ─────────────────────────────────────────────
// Configuration du site (clé/valeur)
// ─────────────────────────────────────────────

model SiteConfig {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Tokens de réinitialisation de mot de passe
// ─────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// ─────────────────────────────────────────────
// Sécurité — Tentatives de connexion (brute force)
// ─────────────────────────────────────────────

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String                        // Email tenté
  ip        String                        // Adresse IP
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ip, createdAt])
}

// Verrouillage progressif par email
model AccountLockout {
  id            String   @id @default(cuid())
  email         String   @unique
  failureCount  Int      @default(0)       // Nombre total d'échecs consécutifs
  lockoutLevel  Int      @default(0)       // Palier actuel (0=pas verrouillé, 1=1min, 2=5min, ...)
  lockedUntil   DateTime?                  // Null = pas verrouillé
  permanent     Boolean  @default(false)   // Blocage définitif
  updatedAt     DateTime @updatedAt

  @@index([email])
}

// ─────────────────────────────────────────────
// Sécurité — Log d'inscription (anti-spam)
// ─────────────────────────────────────────────

model RegistrationLog {
  id        String   @id @default(cuid())
  ip        String
  email     String
  phone     String
  siret     String
  company   String
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
  @@index([phone, createdAt])
  @@index([siret, createdAt])
  @@index([email, createdAt])
}

// ─────────────────────────────────────────────
// Import en masse (produits & images)
// ─────────────────────────────────────────────

enum ImportDraftType {
  PRODUCTS
  IMAGES
}

enum ImportDraftStatus {
  PENDING
  RESOLVED
}

enum ImportJobStatus {
  PENDING
  UPLOADING    // Images: batches still being uploaded
  PROCESSING
  COMPLETED
  FAILED
}

model ImportJob {
  id              String          @id @default(cuid())
  type            ImportDraftType
  status          ImportJobStatus @default(PENDING)
  filename        String?
  totalItems      Int             @default(0)   // total rows or images to process
  processedItems  Int             @default(0)   // processed so far
  successItems    Int             @default(0)
  errorItems      Int             @default(0)
  filePath        String?                       // saved CSV/Excel path on server
  tempDir         String?                       // temp dir for images
  errorDraftId    String?                       // link to ImportDraft if errors
  errorMessage    String?         @db.Text      // global error message if FAILED
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  adminId         String
  admin           User            @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// Alertes de réassort (stock 0 → "Me prévenir")
// ─────────────────────────────────────────────

model RestockAlert {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  productColorId String
  productColor   ProductColor @relation(fields: [productColorId], references: [id], onDelete: Cascade)
  notified       Boolean      @default(false) // true once email sent
  createdAt      DateTime     @default(now())

  @@unique([userId, productId, productColorId])
  @@index([productColorId])
  @@index([notified])
}

model ImportDraft {
  id          String            @id @default(cuid())
  type        ImportDraftType
  status      ImportDraftStatus @default(PENDING)
  filename    String?
  totalRows   Int               @default(0)
  successRows Int               @default(0)
  errorRows   Int               @default(0)
  rows        Json              // Array of rows with errors + metadata
  tempDir     String?           // For image drafts: temp directory path
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  adminId     String
  admin       User              @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
}
