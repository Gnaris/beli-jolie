// Prisma Schema — Beli & Jolie
// Base de données MySQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Rôles utilisateur
// ─────────────────────────────────────────────
enum Role {
  ADMIN
  CLIENT
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  firstName String
  lastName  String
  company   String
  phone     String
  siret     String     @unique
  kbisPath  String
  vatNumber String?    // Numéro TVA intracommunautaire (ex: FR12345678901)
  role      Role       @default(CLIENT)
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  cart      Cart?
  addresses ShippingAddress[]
  orders    Order[]
}

// ─────────────────────────────────────────────
// Catalogue produits
// ─────────────────────────────────────────────

enum SaleType {
  UNIT // Vendu à l'unité
  PACK // Vendu par paquet de X unités
}

enum DiscountType {
  PERCENT // Remise en %
  AMOUNT  // Remise en €
}

// Catégorie principale (ex: Colliers, Bracelets)
model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  slug          String        @unique
  subCategories SubCategory[]
  products      Product[]
  createdAt     DateTime      @default(now())
}

// Sous-catégorie (ex: Sautoir, Jonc)
model SubCategory {
  id         String    @id @default(cuid())
  name       String
  slug       String
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products   Product[] @relation("ProductSubCategories")
  createdAt  DateTime  @default(now())

  @@unique([name, categoryId])
}

// Bibliothèque de couleurs réutilisables entre produits
model Color {
  id            String         @id @default(cuid())
  name          String         @unique
  hex           String?
  createdAt     DateTime       @default(now())
  productColors ProductColor[]
}

// Bibliothèque de compositions (matériaux)
model Composition {
  id        String               @id @default(cuid())
  name      String               @unique
  createdAt DateTime             @default(now())
  products  ProductComposition[]
}

// Liaison produit ↔ composition avec pourcentage
model ProductComposition {
  id            String      @id @default(cuid())
  productId     String
  compositionId String
  percentage    Float       // ex: 85.5 pour 85.5%
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  composition   Composition @relation(fields: [compositionId], references: [id])

  @@unique([productId, compositionId])
}

// Produit principal
model Product {
  id            String               @id @default(cuid())
  reference     String               @unique
  name          String
  description   String               @db.Text
  categoryId    String
  category      Category             @relation(fields: [categoryId], references: [id])
  subCategories SubCategory[]        @relation("ProductSubCategories")
  colors        ProductColor[]
  compositions  ProductComposition[]
  // Produits similaires (M2M self)
  similarProducts ProductSimilar[]   @relation("PSim_A")
  similarTo       ProductSimilar[]   @relation("PSim_B")
  // Dimensions optionnelles (en mm)
  dimensionLength        Float?
  dimensionWidth         Float?
  dimensionHeight        Float?
  dimensionDiameter      Float?
  dimensionCircumference Float?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

// Produits similaires (M2M self-relation)
model ProductSimilar {
  productId String
  similarId String
  product   Product @relation("PSim_A", fields: [productId], references: [id], onDelete: Cascade)
  similar   Product @relation("PSim_B", fields: [similarId], references: [id], onDelete: Cascade)

  @@id([productId, similarId])
}

// Variante couleur d'un produit — prix unitaire et poids partagés entre UNIT et PACK
model ProductColor {
  id          String         @id @default(cuid())
  productId   String
  product     Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorId     String
  color       Color          @relation(fields: [colorId], references: [id])
  unitPrice   Float          // Prix par unité HT — partagé entre UNIT et PACK
  weight      Float          // Poids en kg (ex: 0.008)
  stock       Int            @default(0) // Stock commun à toutes les options de vente de cette couleur
  isPrimary   Boolean        @default(false)
  saleOptions SaleOption[]
  images      ProductImage[] // Max 5 images — partagées entre UNIT et PACK
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([productId, colorId])
}

// Option de vente pour une couleur (unité ou paquet)
model SaleOption {
  id            String        @id @default(cuid())
  colorId       String
  productColor  ProductColor  @relation(fields: [colorId], references: [id], onDelete: Cascade)
  saleType      SaleType      // UNIT ou PACK
  packQuantity  Int?          // Quantité par paquet (null si UNIT)
  size          String?       // Taille (ex: 17, 18, L, XL) — optionnel
  discountType  DiscountType? // Type de remise (null = pas de remise)
  discountValue Float?        // Valeur de la remise
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  cartItems     CartItem[]
}

// Image d'une variante couleur
model ProductImage {
  id        String       @id @default(cuid())
  colorId   String
  color     ProductColor @relation(fields: [colorId], references: [id], onDelete: Cascade)
  path      String       // Chemin relatif depuis /public
  order     Int          @default(0)
  createdAt DateTime     @default(now())
}

// ─────────────────────────────────────────────
// Panier & commandes
// ─────────────────────────────────────────────

// Panier persistant en base (un par utilisateur)
model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// Ligne du panier — liée à une option de vente
model CartItem {
  id           String     @id @default(cuid())
  cartId       String
  cart         Cart       @relation(fields: [cartId], references: [id], onDelete: Cascade)
  saleOptionId String
  saleOption   SaleOption @relation(fields: [saleOptionId], references: [id])
  quantity     Int        @default(1)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([cartId, saleOptionId])
}

// ─────────────────────────────────────────────
// Commandes
// ─────────────────────────────────────────────

enum OrderStatus {
  PENDING     // En attente de traitement
  PROCESSING  // En préparation
  SHIPPED     // Expédiée
  DELIVERED   // Livrée
  CANCELLED   // Annulée
}

// Commande validée par le client
model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique // ex: BJ-2026-000001
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  items       OrderItem[]
  status      OrderStatus @default(PENDING)

  // Snapshot adresse de livraison
  shipLabel     String
  shipFirstName String
  shipLastName  String
  shipCompany   String?
  shipAddress1  String
  shipAddress2  String?
  shipZipCode   String
  shipCity      String
  shipCountry   String

  // Snapshot client
  clientCompany   String
  clientEmail     String
  clientPhone     String
  clientSiret     String
  clientVatNumber String?

  // Transporteur
  carrierId    String
  carrierName  String
  carrierPrice Float

  // TVA
  tvaRate    Float  // ex: 0.20
  subtotalHT Float
  tvaAmount  Float
  totalTTC   Float

  // Easy-Express
  eeTrackingId String?  // Numéro de suivi
  eeLabelUrl   String?  // URL du bordereau PDF @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Ligne de commande (snapshot produit au moment de la commande)
model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productName String
  productRef  String
  colorName   String
  saleType    String  // "UNIT" | "PACK"
  packQty     Int?
  size        String?
  imagePath   String? // première image (relatif /public)

  unitPrice   Float   // prix unitaire calculé (remise incluse)
  quantity    Int
  lineTotal   Float

  createdAt DateTime @default(now())
}

// Adresse de livraison (plusieurs par utilisateur)
model ShippingAddress {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String   // ex: "Boutique principale"
  firstName  String
  lastName   String
  company    String?
  address1   String
  address2   String?
  zipCode    String
  city       String
  country    String   @default("FR")
  phone      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
