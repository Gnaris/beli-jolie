# ── Base de données ────────────────────────────────────────────────────────────
DATABASE_URL="mysql://root@localhost:3306/beli_jolie"

# ── NextAuth ───────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="<random_base64_string_min_32_chars>"
NEXTAUTH_URL="http://localhost:3000"

# ── Compte administrateur (utilisé par scripts/create-admin.ts) ────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="<mot_de_passe_admin>"

# ── Easy-Express (transporteurs) ───────────────────────────────────────────────
EASY_EXPRESS_API_KEY="<bearer_token_easy_express>"

# Adresse expéditeur (votre entrepôt / dépôt)
EE_SENDER_COMPANY="Nom de votre société"
EE_SENDER_SHOP_NAME="Nom de la boutique"
EE_SENDER_SIRET="<14_chiffres>"
EE_SENDER_EMAIL="expedition@example.com"
EE_SENDER_PHONE="0600000000"
EE_SENDER_MOBILE="0600000000"
EE_SENDER_STREET="1 rue de l'Exemple"
EE_SENDER_CITY="PARIS"
EE_SENDER_POSTAL_CODE="75001"
EE_SENDER_COUNTRY="FR"

# ── Stripe (paiement) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Notifications Gmail ────────────────────────────────────────────────────────
# Créer un "Mot de passe d'application" dans les paramètres de sécurité Google
GMAIL_USER="votre.email@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
NOTIFY_EMAIL="notification@example.com"
