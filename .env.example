# ── Base de données ────────────────────────────────────────────────────────────
DATABASE_URL="mysql://root@localhost:3306/b2b_saas"

# ── NextAuth ───────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="<random_base64_string_min_32_chars>"
NEXTAUTH_URL="http://localhost:3000"

# ── Chiffrement des secrets en BDD (AES-256-GCM) ─────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="<base64_32_bytes>"

# ── Compte administrateur (utilisé par scripts/create-admin.ts) ────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="<mot_de_passe_admin>"

# ── IA — Génération automatique nom/description produit (Anthropic Claude) ─────
# Créer une clé sur console.anthropic.com (pay-as-you-go, ~$0.003-0.005 par produit)
ANTHROPIC_API_KEY="sk-ant-..."

# ──────────────────────────────────────────────────────────────────────────────
# Les clés suivantes sont optionnelles en env var — elles peuvent être
# configurées depuis l'interface admin (Paramètres) :
#   - Gmail (GMAIL_USER, GMAIL_APP_PASSWORD, NOTIFY_EMAIL)
#   - Easy-Express (EASY_EXPRESS_API_KEY)
#   - Stripe (STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY)
#   - DeepL (DEEPL_API_KEY)
#   - PFS (PFS_EMAIL, PFS_PASSWORD)
# Les paramètres admin sont prioritaires sur les variables d'environnement.
# ──────────────────────────────────────────────────────────────────────────────
