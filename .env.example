# ── Base de données ────────────────────────────────────────────────────────────
DATABASE_URL="mysql://root@localhost:3306/b2b_saas"

# ── NextAuth ───────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="<random_base64_string_min_32_chars>"
NEXTAUTH_URL="http://localhost:3000"

# ── Chiffrement des secrets en BDD (AES-256-GCM) ─────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="<base64_32_bytes>"

# ── IA — Génération automatique nom/description produit (Anthropic Claude) ─────
# Créer une clé sur console.anthropic.com (pay-as-you-go, ~$0.003-0.005 par produit)
ANTHROPIC_API_KEY="sk-ant-..."

# ── Stripe Connect (plateforme) ──────────────────────────────────────────────
# Configuré par le déployeur (toi), PAS par le client.
# Commission plateforme : se configure sur dashboard.stripe.com → Connect → Fees.
# Clé secrète de ton compte Stripe plateforme (Developers → API keys)
STRIPE_PLATFORM_SECRET_KEY="sk_..."
# Clé publique de ton compte Stripe plateforme (nécessaire pour le checkout)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_..."
