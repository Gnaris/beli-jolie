# ── Base de données ────────────────────────────────────────────────────────────
DATABASE_URL="mysql://root@localhost:3306/b2b_saas"

# ── NextAuth ───────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="<random_base64_string_min_32_chars>"
NEXTAUTH_URL="http://localhost:3000"

# ── Chiffrement des secrets en BDD (AES-256-GCM) ─────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="<base64_32_bytes>"

# ── Stockage images ─────────────────────────────────────────────────────────
# Les images sont stockées localement sur le disque, dans le dossier /public/uploads
# du projet. Aucune configuration externe n'est nécessaire.

# ── Stripe Connect (plateforme) ──────────────────────────────────────────────
# Configuré par le déployeur (toi), PAS par le client.
# Commission plateforme : se configure sur dashboard.stripe.com → Connect → Fees.
STRIPE_PLATFORM_SECRET_KEY="sk_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_..."

# ══════════════════════════════════════════════════════════════════════════════
# Variables optionnelles — configurables aussi via l'interface admin (Paramètres)
# Les valeurs admin prennent priorité sur ces variables d'environnement.
# ══════════════════════════════════════════════════════════════════════════════

# ── Stripe (par client, mode manuel sans Connect) ────────────────────────────
# STRIPE_SECRET_KEY="sk_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email (SMTP via nodemailer) ─────────────────────────────────────────────
# Les identifiants SMTP de votre hébergeur (Hostinger, OVH, Gmail, etc.).
# À saisir de préférence dans Admin → Paramètres → Email (UI prime sur l'env).
# Hostinger : host smtp.hostinger.com, port 465, SMTP_SECURE=true
# Gmail : host smtp.gmail.com, port 587, SMTP_SECURE=false (mot de passe d'application requis)
# SMTP_HOST="smtp.hostinger.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="contact@votreboutique.com"
# SMTP_PASSWORD="..."
# SMTP_FROM_EMAIL="contact@votreboutique.com"
# SMTP_FROM_NAME="Votre Boutique"
# NOTIFY_EMAIL="admin@votreboutique.com"

# ── Traduction automatique (DeepL Free — 500K chars/mois) ───────────────────
# DEEPL_API_KEY="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx"

# ── Transporteur (Easy-Express) ─────────────────────────────────────────────
# EASY_EXPRESS_API_KEY="..."

# ── PFS / eFashion (sync marketplace) ───────────────────────────────────────
# PFS_EMAIL="votre-email@pfs.com"
# PFS_PASSWORD="..."

# ── Ankorstore (callback webhook) ───────────────────────────────────────────
# URL publique HTTPS où Ankorstore peut nous joindre pour notifier la fin d'une
# opération catalogue (push/update/delete). Fallback sur NEXTAUTH_URL si absent.
# En dev : utiliser un tunnel ngrok (ex: `ngrok http --url=<sous-domaine>.ngrok-free.dev 3000`)
# En prod : l'URL publique du site (ex: https://votreboutique.com)
# ANKORSTORE_CALLBACK_URL="https://<sous-domaine>.ngrok-free.dev"
